# Supabase Dashboard > Connect > ORM > Prisma
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="mojuri-uploads"

# Optional: required by Prisma-backed product/order APIs, not by Supabase Auth.
# Runtime pooler (port 6543, add pgbouncer=true)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection used only by Prisma migrations (port 5432)
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173
ADMIN_EMAIL=admin@mojuri.local
ADMIN_PASSWORD=Admin@123
